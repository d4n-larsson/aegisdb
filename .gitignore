# Build output
build/
*.o
*.a
*.so
*.exe
*.out

# Runtime data directory
data/
*.log
*.index
*.time
*.tags
*.semantic
*.compaction
metadata.db

# Local Claude Code config (per-developer; instantiate from integrations/claude-code/examples/mcp.json)
.mcp.json

# Local docker-compose config (per-deployment; instantiate from .env.example).
# The example is committed; a real .env may hold tokens, so keep it local.
.env

# Spec-kit workflow artifacts — kept local, never published
/specs/
/.specify/
/.claude/skills/

# Editor / OS
.DS_Store
Thumbs.db
*.swp
*.tmp
.vscode/
.idea/

# Test artifacts
tests/**/*.bin
core

# Fuzz seed corpus is generated (make fuzz-corpus) — not committed. Only the
# hand-curated crashers under corpus/crashers/ are tracked (regression guards).
tests/fuzz/corpus/record/
tests/fuzz/corpus/wire/

# Python (integrations/claude-code)
__pycache__/
*.pyc
.venv/
venv/
dist/
*.egg-info/
.pytest_cache/
# Local backup tarballs (docker compose --profile backup)
backups/
