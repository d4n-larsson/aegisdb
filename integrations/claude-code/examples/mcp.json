{
  "mcpServers": {
    "memory": {
      "command": "python3",
      "args": ["-m", "aegis_mcp.server"],
      "env": {
        "AEGIS_HOST": "127.0.0.1",
        "AEGIS_PORT": "9470",
        "AEGIS_NAMESPACE": "my-project",
        "AEGIS_AUTH_TOKEN": "",
        "AEGIS_EMBEDDING_DIMENSIONS": "1024"
      }
    }
  }
}