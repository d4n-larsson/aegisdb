{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "uvx --from aegis-mcp aegis-recall-hook"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "uvx --from aegis-mcp aegis-capture-hook"
          }
        ]
      }
    ]
  }
}