{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "uvx --from aegisdb-mcp aegisdb-recall-hook"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "uvx --from aegisdb-mcp aegisdb-capture-hook"
          }
        ]
      }
    ]
  }
}