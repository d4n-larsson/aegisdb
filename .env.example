# AegisDB docker-compose configuration.
#
# Copy to .env and edit — `docker compose` auto-loads it:
#   cp .env.example .env
# Every value has a default (shown), so an absent .env still runs a sane server.
# These are compose-interpolation variables that fill the server's CLI flags;
# the server itself is flag-driven, not environment-driven.

# --- Networking ---------------------------------------------------------------
# TCP port the server listens on (inside the container).
AEGIS_PORT=9470
# Host port to publish it on (defaults to AEGIS_PORT). Change to run several
# instances, or to avoid a clash on the host.
AEGIS_HOST_PORT=9470
# Host interface the port is published on. Defaults to loopback (127.0.0.1)
# because the wire protocol is unauthenticated and plaintext by default — do NOT
# expose it off-box until you enable auth (AEGIS_EXTRA_ARGS) and/or front it with
# a TLS-terminating proxy. Set to 0.0.0.0 to publish on all interfaces.
AEGIS_BIND=127.0.0.1

# --- Core ---------------------------------------------------------------------
# Embedding vector length. MUST match every client (the Claude Code MCP
# integration defaults to 384). Changing it after data exists requires a reload.
AEGIS_EMBEDDING_DIM=384
# Highest enabled feature phase (1-4). 4 = everything; rarely changed.
AEGIS_PHASE=4
# Log verbosity: error | warn | info | debug.
AEGIS_LOG_LEVEL=info

# --- Durability & maintenance -------------------------------------------------
# fsync policy: sync (per write) | batch (per N writes) | interval (time-based).
AEGIS_DURABILITY=interval
# Index checkpoint cadence in seconds so recovery replays only the tail; 0 off.
AEGIS_CHECKPOINT_SEC=60
# Log-compaction check cadence in seconds (compacts only when enough is dead);
# 0 off.
AEGIS_COMPACT_SEC=300

# --- Per-tenant limits (shared multi-tenant servers) --------------------------
# Enforced only when auth is enabled (namespaced tokens). 0 = unlimited.
# Bound what one tenant can consume so a runaway agent can't degrade everyone.
AEGIS_TENANT_MAX_RECORDS=0
AEGIS_TENANT_MAX_BYTES=0
# Per-namespace request rate limit (req/s, burst = 1s). 0 = unlimited.
AEGIS_TENANT_RATE_QPS=0

# --- Lifecycle ----------------------------------------------------------------
# Grace period for a clean shutdown (log flush + checkpoint) before SIGKILL.
AEGIS_STOP_GRACE=30s

# --- Anything else ------------------------------------------------------------
# Extra CLI flags passed verbatim (space-separated) for options without a named
# var above. Examples (uncomment/adapt in your .env):
#   # Require auth (mount tokens.txt — see the volumes note in compose):
#   AEGIS_EXTRA_ARGS=--auth-token-file /data/tokens.txt
#   # Encrypt the log + checkpoints at rest (mount a key file; `aegisdb gen-key`
#   # mints one). Keep the key OFF the data volume; without it data is lost.
#   AEGIS_EXTRA_ARGS=--encryption-key-file /run/secrets/aegis.key
#   # Combine several:
#   AEGIS_EXTRA_ARGS=--io-threads 8 --max-payload 4194304 --ann-quantize
#   # ANN tuning: --ann-threshold, --ann-ef-search, --ann-shard-target,
#   #             --ann-quantize (int8 vectors)
#   # Durability tuning: --fsync-batch (batch mode), --fsync-interval-ms (interval)
#   # Working memory: --working-capacity
AEGIS_EXTRA_ARGS=

# --- Off-box backups (opt-in: `docker compose --profile backup up`) -----------
# The backup sidecar takes a consistent online snapshot on an interval, tarballs
# it to the host ./backups dir, and (if an upload command is set) ships it to
# remote storage. Restart + the volume survive a crash; this survives losing the
# whole box. See scripts/aegis-backup.sh.
#
# Admin token the backup client sends (required only if the server enforces auth).
# AEGIS_AUTH_TOKEN=
# Off-box transport; "{}" is replaced with the tarball path. Unset = keep on the
# host ./backups dir only (off the volume, but not off the box). Examples:
#   AEGIS_BACKUP_UPLOAD_CMD=aws s3 cp {} s3://my-bucket/aegis/
#   AEGIS_BACKUP_UPLOAD_CMD=rclone copy {} remote:aegis
#   AEGIS_BACKUP_UPLOAD_CMD=rsync -a {} backups.example.com:/aegis/
# (the tool must exist in the sidecar image — swap `image:` or use host cron)
AEGIS_BACKUP_UPLOAD_CMD=
# Seconds between backups (default 86400 = daily).
AEGIS_BACKUP_INTERVAL=86400
# Local tarballs to keep before pruning the oldest.
AEGIS_BACKUP_RETAIN=7

# --- Resource limits (optional; see the commented deploy block in compose) ----
# AegisDB keeps indexes in RAM, so size memory to your dataset — a too-low cap
# OOM-kills live memories. Uncomment the deploy block in docker-compose.yml to
# use these.
# AEGIS_MEM_LIMIT=1g
# AEGIS_CPUS=2